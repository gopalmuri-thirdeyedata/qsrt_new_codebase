# ════════════════════════════════════════════════════════════════
# KitchEye — Environment Configuration
# Copy this file to .env and fill in your real values
# NEVER commit .env to Git — it contains secrets
# ════════════════════════════════════════════════════════════════


# ── Qubeyond Webhook Security ─────────────────────────────────
# The secret key Qubeyond uses to sign webhook requests.
# Get this from: Qubeyond Portal → Settings → Integrations → Webhooks → Secret
# Leave blank during local dev to skip signature validation
QUBEYOND_WEBHOOK_SECRET=


# ── Qubeyond API Credentials ──────────────────────────────────
# Your Qubeyond REST API base URL
# Provided by Qubeyond — check their developer docs for the correct URL
QUBEYOND_API_BASE_URL=https://api.qubeyond.com

# Your Qubeyond API key or Bearer token
# Get this from: Qubeyond Portal → Settings → API Keys
QUBEYOND_API_KEY=

# Your Qubeyond tenant / account ID (if required by their API)
QUBEYOND_TENANT_ID=

# Your Qubeyond outlet / location ID
# Used to filter orders for this specific restaurant location
QUBEYOND_OUTLET_ID=


# ── Camera Relay (local_relay.py) ─────────────────────────────
# The WebSocket base URL of your cloud FastAPI server
# Example (RunPod):       wss://c2lyv8int2fk1m-8000.proxy.runpod.net
# Example (custom domain): wss://yourdomain.com
CLOUD_WS_BASE=ws://localhost:8000

# RTSP URLs for each physical camera station
# Format: rtsp://username:password@ip_address:port/stream_path
CAM_1=rtsp://admin:password@192.168.1.101:554/stream1
CAM_2=rtsp://admin:password@192.168.1.102:554/stream1
CAM_3=rtsp://admin:password@192.168.1.103:554/stream1
CAM_4=rtsp://admin:password@192.168.1.104:554/stream1


# ── Server Settings ───────────────────────────────────────────
# Host and port the FastAPI server listens on
# (Used when running with uvicorn main:app directly)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
